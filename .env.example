# =============================================================================
# ODIN - Environment Configuration
# =============================================================================
# Copy this file to .env and update the values for your environment.
# NEVER commit .env to version control.
#
# REQUIRED (for production): S3_ACCESS_KEY, S3_SECRET_KEY, NEO4J_PASSWORD,
#   POSTGRES_PASSWORD, GRAFANA_PASSWORD
#   The API will start with fallback values for local development if these
#   are not set, but a warning will be logged. Always set them explicitly
#   in production.
# =============================================================================

# --- API Server ---
ODIN_PORT=3001
ODIN_CORS_ORIGINS=http://localhost:3000,http://localhost:80
RUST_LOG=odin_api=info,tower_http=info

# --- PostgreSQL ---
DATABASE_URL=postgresql://odin:${POSTGRES_PASSWORD:-odin}@localhost:5432/odin
POSTGRES_PASSWORD=odin

# --- Qdrant (Vector Store) ---
QDRANT_URL=http://localhost:6333

# --- Redis (Cache) ---
REDIS_URL=redis://localhost:6379

# --- Neo4j (Graph Store) ---
NEO4J_URL=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=odin

# --- Ollama (Local AI) ---
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_REASON_MODEL=qwen3:8b

# --- S3 / MinIO (Artifact Storage) ---
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=odin-artifacts
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# --- Grafana (Docker Compose only) ---
GRAFANA_PASSWORD=odin-grafana
